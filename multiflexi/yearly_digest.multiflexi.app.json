{
  "$schema": "https://raw.githubusercontent.com/VitexSoftware/php-vitexsoftware-multiflexi-core/refs/heads/main/multiflexi.app.schema.json",
  "schemaVersion": "3.3.0",
  "uuid": "ff7d9f0e-e829-4a60-b3e6-198c1826c82b",
  "name": {
    "en": "Yearly Digest",
    "cs": "Roční Digest"
  },
  "description": {
    "en": "Generate AbraFlexi report every year",
    "cs": "Generovat roční zprávu AbraFlexi"
  },
  "version": "1.33.1",
  "author": "Vitex Software",
  "license": "MIT",
  "category": "Analytics",
  "requirements": [
    "AbraFlexi",
    "Mail"
  ],
  "tags": [
    "AbraFlexi",
    "Digest",
    "Analytics",
    "Sensor",
    "Yearly"
  ],
  "homepage": "https://github.com/VitexSoftware/AbraFlexi-Digest/",
  "repository": "https://github.com/VitexSoftware/AbraFlexi-Digest",
  "image": "",
  "executable": "/usr/bin/abraflexi-yeardigest",
  "environment": {
    "ABRAFLEXI_COMPANY": {
      "type": "string",
      "description": {
        "en": "AbraFlexi Company Database",
        "cs": "Databáze společnosti v AbraFlexi"
      },
      "defval": "demo_de",
      "required": true,
      "category": "API"
    },
    "ABRAFLEXI_LOGIN": {
      "type": "string",
      "description": {
        "en": "AbraFlexi Login Username",
        "cs": "Přihlašovací jméno do AbraFlexi"
      },
      "defval": "winstrom",
      "required": true,
      "category": "API"
    },
    "ABRAFLEXI_PASSWORD": {
      "type": "password",
      "description": {
        "en": "AbraFlexi Password",
        "cs": "Heslo do AbraFlexi"
      },
      "defval": "winstrom",
      "required": true,
      "category": "API"
    },
    "ABRAFLEXI_URL": {
      "type": "string",
      "description": {
        "en": "AbraFlexi Server URL",
        "cs": "URL adresa AbraFlexi serveru"
      },
      "defval": "https://demo.flexibee.eu:5434",
      "required": true,
      "category": "API"
    },
    "THEME": {
      "type": "string",
      "description": {
        "en": "Report Theme",
        "cs": "Téma reportu"
      },
      "defval": "happy",
      "required": false,
      "category": "Other"
    },
    "DIGEST_CHECK_SUPPLIER_CONTACT": {
      "type": "bool",
      "description": {
        "en": "Check if supplier has contact details",
        "cs": "Kontrolovat, zda má dodavatel kontaktní údaje"
      },
      "defval": true,
      "required": false,
      "category": "Behavior"
    },
    "DIGEST_FROM": {
      "type": "string",
      "description": {
        "en": "Digest Email Sender Address",
        "cs": "Odesílatel digestu"
      },
      "defval": "noreply@example.com",
      "required": false,
      "category": "Other"
    },
    "DIGEST_MAILTO": {
      "type": "string",
      "description": {
        "en": "Send Digest to Email Address",
        "cs": "Poslat digest na emailovou adresu"
      },
      "defval": "",
      "required": false,
      "category": "Other"
    },
    "RESULT_FILE": {
      "type": "string",
      "description": {
        "en": "Save Output to File",
        "cs": "Uložit výstup do souboru"
      },
      "defval": "yearly_digest.html",
      "required": false,
      "category": "Other"
    },
    "EASE_LOGGER": {
      "type": "string",
      "description": {
        "en": "Logging Method",
        "cs": "Způsob logování"
      },
      "defval": "console",
      "required": false,
      "category": "Behavior"
    }
  },
  "artifacts": [
    {
      "name": "Yearly Digest Report",
      "path": "${RESULT_FILE}",
      "type": "html",
      "description": {
        "en": "The yearly digest report generated by the application.",
        "cs": "Roční digest report generovaný aplikací."
      }
    }
  ]
}
