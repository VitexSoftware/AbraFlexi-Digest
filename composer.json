{
    "name": "vitexsoftware/abraflexi-digest",
    "description": "Periodical AbraFlexi digest — Markdown, HTML, PDF output.",
    "version": "dev-main",
    "authors": [
        {
            "name": "Vitex",
            "email": "info@vitexsoftware.cz"
        }
    ],
    "minimum-stability": "dev",
    "license": "MIT",
    "type": "project",
    "require": {
        "php": ">=8.1",
        "vitexsoftware/digest-modules": "dev-main",
        "vitexsoftware/digest-renderer": "dev-main",
        "spojenet/flexibee": "*",
        "symfony/mailer": "^6.4|^7.0",
        "symfony/mime": "^6.4|^7.0",
        "vitexsoftware/ease-core-bricks": "^1.2"
    },
    "repositories": [],
    "autoload": {
        "psr-4": {
            "AbraFlexi\\Digest\\": "src/Digest/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "*",
        "phpstan/phpstan": "*",
        "friendsofphp/php-cs-fixer": "^3.93",
        "ergebnis/composer-normalize": "^2.52",
        "ergebnis/php-cs-fixer-config": "^6.59"
    },
    "config": {
        "allow-plugins": {
            "ergebnis/composer-normalize": true
        }
    }
}
